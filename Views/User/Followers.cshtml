@using WebApplication1.ViewModels
@model UserProfileViewModel

@{
    ViewData["Title"] = "Followers";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-8 offset-md-2">
            <div class="d-flex align-items-center mb-4">
                <a href="@Url.Action("Profile", "User", new { id = Model.User.Id })" class="btn btn-link">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <h2 class="ms-3 mb-0">Người theo dõi @Model.User.DisplayName</h2>
            </div>

            @if (Model.Followers != null && Model.Followers.Any())
            {
                <div class="list-group">
                    @foreach (var follower in Model.Followers)
                    {
                        <div class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(follower.Avatar))
                                    {
                                        <img src="@follower.Avatar" alt="@follower.DisplayName" class="rounded-circle me-3" width="40" height="40" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                    }
                                    <div>
                                        <h5 class="mb-0">
                                            <a href="@Url.Action("Profile", "User", new { id = follower.Id })" class="text-decoration-none">
                                                @follower.DisplayName
                                            </a>
                                        </h5>
                                        <small class="text-muted">@@follower.UserName</small>
                                    </div>
                                </div>

                                <div>
                                    @if (User.Identity?.IsAuthenticated == true && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value != follower.Id)
                                    {
                                        <form method="post" action="@Url.Action("Follow", "User", new { id = follower.Id })" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-person-plus"></i> Follow
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> Chưa có người theo dõi
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
}
