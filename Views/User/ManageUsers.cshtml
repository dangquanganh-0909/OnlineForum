@model List<dynamic>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    var currentPage = (int)ViewData["CurrentPage"];
    var totalPages = (int)ViewData["TotalPages"];
    var search = ViewData["Search"]?.ToString();
}

<div class="container" style="margin-top: 24px;">
    <div class="card">
        <div class="card-header">
            <h1 class="card-title">
                <i class="fas fa-users"></i> Quản Lý Người Dùng
            </h1>
        </div>

        <!-- Search Form -->
        <div style="margin-bottom: 24px;">
            <form method="get" style="display: flex; gap: 12px; align-items: center;">
                <div style="flex: 1;">
                    <input type="text" name="search" class="form-control" 
                           placeholder="Tìm kiếm theo tên, email..." 
                           value="@search" />
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Tìm Kiếm
                </button>
            </form>
        </div>

        <!-- Users Table -->
        <div style="overflow-x: auto;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Người Dùng</th>
                        <th>Email</th>
                        <th>Vai Trò</th>
                        <th>Trạng Thái</th>
                        <th>Ngày Tham Gia</th>
                        <th>Bài Viết</th>
                        <th>Bình Luận</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (dynamic userInfo in Model)
                    {
                        var user = userInfo.User;
                        var roles = userInfo.Roles as IList<string>;
                        var postCount = (int)userInfo.PostCount;
                        var commentCount = (int)userInfo.CommentCount;
                        
                        <tr style="@(!user.IsActive ? "opacity: 0.6; background-color: #ffeaa7;" : "")">
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    @if (!string.IsNullOrEmpty(user.Avatar))
                                    {
                                        <img src="@user.Avatar" alt="Avatar" 
                                             style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background-color: var(--primary-color); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                                            @((user.DisplayName ?? user.UserName)?.Substring(0, 1).ToUpper())
                                        </div>
                                    }
                                    <div>
                                        <div style="font-weight: 600;">
                                            <a asp-action="Profile" asp-route-id="@user.Id">
                                                @(user.DisplayName ?? user.UserName)
                                            </a>
                                        </div>
                                        @if (!string.IsNullOrEmpty(user.DisplayName))
                                        {
                                            <div style="font-size: 0.9rem; color: var(--text-muted);">
                                                @user.UserName
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (roles.Any())
                                {
                                    @foreach (var role in roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : role == "Moderator" ? "bg-warning" : "bg-secondary")">
                                            @role
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Người dùng</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check"></i> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="fas fa-lock"></i> Bị khóa
                                    </span>
                                }
                            </td>
                            <td>@user.JoinDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-primary">@postCount</span>
                            </td>
                            <td>
                                <span class="badge bg-info">@commentCount</span>
                            </td>
                            <td>
                                @{
                                    var currentUserId = ViewContext.HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                    var isCurrentUser = user.Id == currentUserId;
                                }
                                
                                @if (!isCurrentUser)
                                {
                                    <div style="display: flex; gap: 8px;">
                                        <a asp-action="Profile" asp-route-id="@user.Id" class="btn btn-outline btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        
                                        <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" style="display: inline;"
                                              onsubmit="return confirm('@(user.IsActive ? "Bạn có chắc chắn muốn khóa tài khoản này?" : "Bạn có chắc chắn muốn mở khóa tài khoản này?")')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") btn-sm">
                                                <i class="fas fa-@(user.IsActive ? "lock" : "unlock")"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Bạn</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div style="display: flex; justify-content: center; align-items: center; gap: 12px; margin-top: 24px;">
                @if (currentPage > 1)
                {
                    <a asp-action="ManageUsers" asp-route-page="@(currentPage - 1)" asp-route-search="@search" 
                       class="btn btn-outline btn-sm">
                        <i class="fas fa-chevron-left"></i> Trước
                    </a>
                }

                <span>Trang @currentPage / @totalPages</span>

                @if (currentPage < totalPages)
                {
                    <a asp-action="ManageUsers" asp-route-page="@(currentPage + 1)" asp-route-search="@search" 
                       class="btn btn-outline btn-sm">
                        Sau <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        }
    </div>
</div>