@model WebApplication1.ViewModels.UserProfileViewModel
@{
    ViewData["Title"] = $"{Model.User.DisplayName ?? Model.User.UserName}'s Profile";
    var isOwnProfile = User.Identity!.IsAuthenticated && Model.User.Id == ViewContext.HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container" style="margin-top: 24px;">
    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 24px;">
        <!-- Main Content -->
        <div>
            <!-- Profile Header -->
            <div class="card">
                <div style="display: flex; align-items: center; gap: 24px;">
                    <div>
                        @if (!string.IsNullOrEmpty(Model.User.Avatar))
                        {
                            <img src="@Model.User.Avatar" alt="Avatar" 
                                 style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary-color);" />
                        }
                        else
                        {
                            <div style="width: 100px; height: 100px; border-radius: 50%; background-color: var(--primary-color); display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: bold;">
                                @((Model.User.DisplayName ?? Model.User.UserName)?.Substring(0, 1).ToUpper())
                            </div>
                        }
                    </div>
                    
                    <div style="flex: 1;">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                            <h1 style="margin: 0;">@(Model.User.DisplayName ?? Model.User.UserName)</h1>
                            @if (!Model.User.IsActive)
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-lock"></i> Tài khoản bị khóa
                                </span>
                            }
                        </div>
                        <p class="text-muted" style="margin: 0 0 12px 0;">
                            <i class="fas fa-calendar"></i> Thành viên từ @Model.User.JoinDate.ToString("MMMM yyyy")
                        </p>
                        
                        @if (!string.IsNullOrEmpty(Model.User.Bio))
                        {
                            <p style="margin: 0;">@Model.User.Bio</p>
                        }
                        
                        <!-- Follow Statistics -->
                        <div style="margin-top: 12px; display: flex; gap: 24px;">
                            <div>
                                <a href="@Url.Action("Followers", "User", new { id = Model.User.Id })" style="text-decoration: none; color: inherit;">
                                    <strong>@(Model.Followers?.Count() ?? 0)</strong>
                                    <span class="text-muted">Người theo dõi</span>
                                </a>
                            </div>
                            <div>
                                <a href="@Url.Action("Following", "User", new { id = Model.User.Id })" style="text-decoration: none; color: inherit;">
                                    <strong>@(Model.Following?.Count() ?? 0)</strong>
                                    <span class="text-muted">Đang theo dõi</span>
                                </a>
                            </div>
                        </div>
                        
                        @if (isOwnProfile)
                        {
                            <div style="margin-top: 16px;">
                                <a asp-action="Edit" class="btn btn-primary">
                                    <i class="fas fa-edit"></i> Chỉnh Sửa Hồ Sơ
                                </a>
                            </div>
                        }
                        else if (User.Identity?.IsAuthenticated == true)
                        {
                            <div style="margin-top: 16px;">
                                <form method="post" action="@Url.Action("Follow", "User", new { id = Model.User.Id })" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn @(Model.IsFollowing ? "btn-danger" : "btn-primary")">
                                        <i class="fas fa-@(Model.IsFollowing ? "user-minus" : "user-plus")"></i>
                                        @(Model.IsFollowing ? "Bỏ Theo Dõi" : "Theo Dõi")
                                    </button>
                                </form>
                            </div>
                        }

                        @* Admin Controls *@
                        @if (User.IsInRole("Admin") && !isOwnProfile)
                        {
                            <form asp-action="ToggleActive" asp-route-id="@Model.User.Id" method="post" style="margin-top: 16px; display: inline;"
                                  onsubmit="return confirm('@(Model.User.IsActive ? "Bạn có chắc chắn muốn khóa tài khoản này?" : "Bạn có chắc chắn muốn mở khóa tài khoản này?")')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn @(Model.User.IsActive ? "btn-danger" : "btn-success") btn-sm">
                                    <i class="fas fa-@(Model.User.IsActive ? "lock" : "unlock")"></i>
                                    @(Model.User.IsActive ? "Khóa Tài Khoản" : "Mở Khóa Tài Khoản")
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Tổng Quan Hoạt Động</h2>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 24px;">
                    <div class="text-center">
                        <div style="font-size: 2rem; font-weight: bold; color: var(--primary-color);">@Model.TotalPosts</div>
                        <div class="text-muted">Bài Viết</div>
                    </div>
                    <div class="text-center">
                        <div style="font-size: 2rem; font-weight: bold; color: var(--secondary-color);">@Model.TotalComments</div>
                        <div class="text-muted">Bình Luận</div>
                    </div>
                    <div class="text-center">
                        <div style="font-size: 2rem; font-weight: bold; color: var(--accent-color);">@Model.TotalLikes</div>
                        <div class="text-muted">Lượt Thích Nhận</div>
                    </div>
                </div>
            </div>

            <!-- Recent Posts -->
            @if (Model.RecentPosts.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Bài Viết Gần Đây</h2>
                    </div>
                    
                    @foreach (var post in Model.RecentPosts)
                    {
                        <div style="padding: 16px 0; border-bottom: 1px solid var(--border-color);">
                            <div style="margin-bottom: 8px;">
                                <h3 style="margin: 0; font-size: 1.125rem;">
                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" 
                                       style="text-decoration: none; color: inherit;">
                                        @post.Title
                                    </a>
                                </h3>
                            </div>
                            
                            <div class="post-meta">
                                <span class="tag category" style="background-color: @post.Category.Color;">
                                    @post.Category.Name
                                </span>
                                <span>
                                    <i class="fas fa-clock"></i>
                                    @post.CreatedAt.ToString("MMM dd, yyyy")
                                </span>
                                <span>
                                    <i class="fas fa-heart"></i>
                                    @post.PostLikes.Count likes
                                </span>
                                <span>
                                    <i class="fas fa-comment"></i>
                                    @post.Comments.Count bình luận
                                </span>
                            </div>
                        </div>
                    }
                    
                    <div style="padding-top: 16px;">
                        <a asp-controller="Post" asp-action="Index" asp-route-userId="@Model.User.Id" class="btn btn-outline">
                            Xem Tất Cả Bài Viết
                        </a>
                    </div>
                </div>
            }

            <!-- Recent Comments -->
            @if (Model.RecentComments.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Bình Luận Gần Đây</h2>
                    </div>
                    
                    @foreach (var comment in Model.RecentComments)
                    {
                        <div style="padding: 16px 0; border-bottom: 1px solid var(--border-color);">
                            <div style="margin-bottom: 8px;">
                                <p style="margin: 0;">@(comment.Content.Length > 100 ? comment.Content.Substring(0, 100) + "..." : comment.Content)</p>
                            </div>
                            
                            <div style="font-size: 0.875rem; color: var(--text-muted);">
                                <span>
                                    <i class="fas fa-comment"></i>
                                    Comment on 
                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@comment.PostId">
                                        @comment.Post.Title
                                    </a>
                                </span>
                                <span style="margin-left: 16px;">
                                    <i class="fas fa-clock"></i>
                                    @comment.CreatedAt.ToString("MMM dd, yyyy")
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!Model.RecentPosts.Any() && !Model.RecentComments.Any())
            {
                <div class="card text-center">
                    <div style="padding: 48px;">
                        <i class="fas fa-user-circle" style="font-size: 4rem; color: var(--text-muted); margin-bottom: 16px;"></i>
                        <h3>Chưa có hoạt động</h3>
                        <p class="text-muted">
                            @if (isOwnProfile)
                            {
                                <text>Bắt đầu tham gia bằng cách tạo bài viết đầu tiên hoặc bình luận vào các cuộc thảo luận hiện tại.</text>
                            }
                            else
                            {
                                <text>This user hasn't posted or commented yet.</text>
                            }
                        </p>
                        @if (isOwnProfile)
                        {
                            <a asp-controller="Post" asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Tạo Bài Viết Đầu Tiên
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-section">
                <h3 class="sidebar-title">Thông Tin Hồ Sơ</h3>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <div class="stat-item">
                        <i class="fas fa-envelope"></i>
                        <span>@Model.User.Email</span>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Tham gia @Model.User.JoinDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    @if (Model.User.IsActive)
                    {
                        <div class="stat-item">
                            <i class="fas fa-check-circle" style="color: var(--secondary-color);"></i>
                            <span>Thành Viên Hoạt Động</span>
                        </div>
                    }
                </div>
            </div>

            @if (isOwnProfile)
            {
                <div class="sidebar-section">
                    <h3 class="sidebar-title">Thao Tác Nhanh</h3>
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <a asp-action="Edit" class="btn btn-primary btn-sm">
                            <i class="fas fa-edit"></i> Edit Profile
                        </a>
                        <a asp-controller="Post" asp-action="Create" class="btn btn-secondary btn-sm">
                            <i class="fas fa-plus"></i> New Post
                        </a>
                        <a asp-action="Notifications" class="btn btn-outline btn-sm">
                            <i class="fas fa-bell"></i> Notifications
                        </a>
                    </div>
                </div>
            }

            <div class="sidebar-section">
                <h3 class="sidebar-title">Chuyển Hướng</h3>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <a asp-controller="Post" asp-action="Index" class="btn btn-outline btn-sm">
                        <i class="fas fa-home"></i> Về Diễn Đàn
                    </a>
                    @if (User.Identity.IsAuthenticated && !isOwnProfile)
                    {
                        <a asp-action="Profile" class="btn btn-outline btn-sm">
                            <i class="fas fa-user"></i> My Profile
                        </a>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <style>
        @@media (max-width: 768px) {
            .container > div {
                grid-template-columns: 1fr !important;
            }
            
            .sidebar {
                order: -1;
                position: static;
            }
            
            .card > div:first-child {
                flex-direction: column !important;
                text-align: center;
            }
            
            .card > div:first-child > div:last-child {
                margin-top: 16px;
            }
        }
    </style>
}
