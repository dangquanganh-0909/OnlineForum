@model List<WebApplication1.Models.CategoryAdmin>
@{
    ViewData["Title"] = "Quản Lý Admin Danh Mục";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-shield-check"></i> Quản Lý Admin Danh Mục
        </h2>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> Hiện không có admin danh mục nào. <a href="@Url.Action("Create", "CategoryAdmin")">Tạo một cái mới</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Tên Danh Mục</th>
                        <th>Admin</th>
                        <th>Ngày Giao</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var admin in Model.OrderBy(a => a.SubCategory.MainCategory.Name).ThenBy(a => a.SubCategory.Name))
                    {
                        <tr>
                            <td>
                                <strong>@admin.SubCategory.MainCategory.Name</strong> > @admin.SubCategory.Name
                            </td>
                            <td>
                                <a href="@Url.Action("Profile", "User", new { id = admin.UserId })">
                                    @(admin.User.DisplayName ?? admin.User.UserName)
                                </a>
                            </td>
                            <td>
                                <small>@admin.AssignedAt.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>
                                @if (admin.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt Động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Không Hoạt Động</span>
                                }
                            </td>
                            <td>
                                @if (admin.IsActive)
                                {
                                    <button type="button" class="btn btn-sm btn-warning" onclick="deactivateAdmin(@admin.Id, '@admin.User.DisplayName')">
                                        <i class="bi bi-x-circle"></i> Vô Hiệu Hóa
                                    </button>
                                }
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteAdmin(@admin.Id, '@admin.User.DisplayName')">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-4">
        <h4>Công Cụ Quản Lý</h4>
        <div class="btn-group" role="group">
            <a href="@Url.Action("ManageUsers", "CategoryAdmin")" class="btn btn-primary">
                <i class="fas fa-users"></i> Quản Lý Người Dùng
            </a>
            <a href="@Url.Action("LockedUsers", "CategoryAdmin")" class="btn btn-danger">
                <i class="fas fa-lock"></i> Xem Người Dùng Khóa
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deactivateAdmin(adminId, adminName) {
            if (confirm('Bạn chắc chắn muốn vô hiệu hóa admin: ' + adminName + '?')) {
                fetch('@Url.Action("Deactivate", "CategoryAdmin")?id=' + adminId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.message) {
                        alert(data.message);
                        location.reload();
                    }
                })
                .catch(error => alert('Lỗi: ' + error.message));
            }
        }

        function deleteAdmin(adminId, adminName) {
            if (confirm('Bạn chắc chắn muốn xóa admin: ' + adminName + '? Hành động này không thể hoàn tác.')) {
                fetch('@Url.Action("Delete", "CategoryAdmin")?id=' + adminId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.message) {
                        alert(data.message);
                        location.reload();
                    }
                })
                .catch(error => alert('Lỗi: ' + error.message));
            }
        }
    </script>
}
