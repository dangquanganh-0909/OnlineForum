@model List<WebApplication1.Models.User>
@{
    ViewData["Title"] = "Người Dùng Bị Khóa";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-lock"></i> Người Dùng Bị Khóa
        </h2>
        <span class="badge bg-danger">@Model.Count người dùng</span>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle"></i> Không có người dùng nào bị khóa.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Tên Người Dùng</th>
                        <th>Email</th>
                        <th>Lý Do Khóa</th>
                        <th>Thời Gian Khóa</th>
                        <th>Admin Khóa</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.OrderByDescending(u => u.LockedAt))
                    {
                        <tr>
                            <td>
                                <strong>@(user.DisplayName ?? user.UserName)</strong>
                            </td>
                            <td>
                                @user.Email
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.LockedReason))
                                {
                                    <p class="mb-0">@user.LockedReason</p>
                                }
                                else
                                {
                                    <span class="text-muted">Không có lý do</span>
                                }
                            </td>
                            <td>
                                @if (user.LockedAt.HasValue)
                                {
                                    <small>@user.LockedAt.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(user.LockedByAdminId))
                                {
                                    <small class="text-muted">@user.LockedByAdminId</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-success" onclick="unlockUser('@user.Id', '@user.DisplayName')">
                                    <i class="bi bi-unlock"></i> Mở Khóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a href="@Url.Action("Index", "CategoryAdmin")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay Lại
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function unlockUser(userId, userName) {
            if (confirm('Bạn chắc chắn muốn mở khóa tài khoản: ' + userName + '?')) {
                fetch('@Url.Action("UnlockUserAccount", "CategoryAdmin")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        userId: userId
                    })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        location.reload();
                    } else {
                        alert('Lỗi: ' + data.message);
                    }
                })
                .catch(error => alert('Lỗi: ' + error.message));
            }
        }
    </script>
}
