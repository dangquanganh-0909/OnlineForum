@model WebApplication1.Models.CategoryAdmin
@{
    ViewData["Title"] = "Thêm Admin Danh Mục";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Thêm Admin Danh Mục
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label">Chọn Người Dùng <span class="text-danger">*</span></label>
                            <select asp-for="UserId" class="form-select" required>
                                <option value="">-- Chọn người dùng --</option>
                                @foreach (var user in ViewBag.UserId.Items)
                                {
                                    <option value="@user.Value">@user.Text</option>
                                }
                            </select>
                            <span asp-validation-for="UserId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SubCategoryId" class="form-label">Chọn Danh Mục <span class="text-danger">*</span></label>
                            <select asp-for="SubCategoryId" class="form-select" required>
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var subCat in ViewBag.SubCategoryId.Items)
                                {
                                    <option value="@subCat.Value">@subCat.Text</option>
                                }
                            </select>
                            <span asp-validation-for="SubCategoryId" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle"></i>
                            <strong>Lưu ý:</strong> Admin danh mục sẽ có quyền:
                            <ul class="mb-0 mt-2">
                                <li>Xem và xử lý report bài viết trong danh mục</li>
                                <li>Khóa tài khoản người vi phạm</li>
                                <li>Xóa bài viết vi phạm nội quy</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1">
                                <i class="bi bi-check-circle"></i> Thêm Admin
                            </button>
                            <a href="@Url.Action("Index", "CategoryAdmin")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay Lại
                            </a>
                        </div>
                    </form>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            @ViewBag.Error
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
