@model List<WebApplication1.Models.User>
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-users"></i> Quản Lý Người Dùng
        </h2>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> Không có người dùng nào trong danh mục của bạn.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Tên Hiển Thị</th>
                        <th>Email</th>
                        <th>Ngày Tham Gia</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.OrderBy(u => u.DisplayName))
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("Profile", "User", new { id = user.Id })">
                                    @user.DisplayName
                                </a>
                            </td>
                            <td>
                                <small>@user.Email</small>
                            </td>
                            <td>
                                <small>@user.JoinDate.ToString("dd/MM/yyyy")</small>
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger">Đã Khóa</span>
                                }
                                else if (user.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt Động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Không Hoạt Động</span>
                                }
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <button type="button" class="btn btn-sm btn-success" onclick="unlockUser('@user.Id', '@user.DisplayName')">
                                        <i class="fas fa-unlock"></i> Mở Khóa
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#lockUserModal" onclick="prepareLockUser('@user.Id', '@user.DisplayName')">
                                        <i class="fas fa-lock"></i> Khóa
                                    </button>
                                }
                                <a href="@Url.Action("Profile", "User", new { id = user.Id })" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> Xem
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Lock User Modal -->
<div class="modal fade" id="lockUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Khóa Tài Khoản</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="lockUserForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="lockReason" class="form-label">Lý Do Khóa *</label>
                        <textarea class="form-control" id="lockReason" name="reason" rows="4" required placeholder="Nhập lý do khóa tài khoản..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger" onclick="submitLockUser()">Khóa Tài Khoản</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let lockUserId = '';
        let lockUserName = '';

        function prepareLockUser(userId, userName) {
            lockUserId = userId;
            lockUserName = userName;
            document.getElementById('lockReason').value = '';
        }

        function submitLockUser() {
            const reason = document.getElementById('lockReason').value;
            
            if (!reason.trim()) {
                alert('Vui lòng nhập lý do khóa tài khoản');
                return;
            }

            fetch('@Url.Action("LockUserAccount", "CategoryAdmin")?userId=' + lockUserId + '&reason=' + encodeURIComponent(reason), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    alert('Tài khoản ' + lockUserName + ' đã được khóa');
                    location.reload();
                } else {
                    alert(data.message || 'Không thể khóa tài khoản');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Lỗi: ' + error);
            });

            bootstrap.Modal.getInstance(document.getElementById('lockUserModal')).hide();
        }

        function unlockUser(userId, userName) {
            if (confirm('Bạn chắc chắn muốn mở khóa tài khoản: ' + userName + '?')) {
                fetch('@Url.Action("UnlockUserAccount", "CategoryAdmin")?userId=' + userId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        alert('Tài khoản ' + userName + ' đã được mở khóa');
                        location.reload();
                    } else {
                        alert(data.message || 'Không thể mở khóa tài khoản');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Lỗi: ' + error);
                });
            }
        }
    </script>
}
