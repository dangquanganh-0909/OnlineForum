@{
    ViewData["Title"] = "Logout Confirmation";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .logout-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            padding: 3rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            max-width: 400px;
            width: 90%;
            text-align: center;
        }
        
        .logout-icon {
            font-size: 3rem;
            color: #dc3545;
            margin-bottom: 1.5rem;
        }
        
        .btn-custom {
            padding: 12px 30px;
            font-size: 1.1rem;
            border-radius: 50px;
            margin: 0.5rem;
            min-width: 120px;
            transition: all 0.3s ease;
        }
        
        .btn-logout {
            background: #dc3545;
            border: none;
            color: white;
        }
        
        .btn-logout:hover {
            background: #c82333;
            color: white;
            transform: translateY(-2px);
        }
        
        .btn-cancel {
            background: #6c757d;
            border: none;
            color: white;
        }
        
        .btn-cancel:hover {
            background: #5a6268;
            color: white;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <div class="logout-card">
        <div class="logout-icon">
            <i class="fas fa-sign-out-alt"></i>
        </div>
        <h2 class="mb-3">Đăng xuất</h2>
        <p class="mb-4">Bạn có chắc chắn muốn đăng xuất không?</p>
        
        <form method="post" action="@Url.Action("Logout", "SimpleAuth")" style="display: inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-logout btn-custom">
                <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
            </button>
        </form>
        
        <a href="javascript:history.back()" class="btn btn-cancel btn-custom">
            <i class="fas fa-times me-2"></i>Hủy
        </a>
    </div>
</body>
</html>