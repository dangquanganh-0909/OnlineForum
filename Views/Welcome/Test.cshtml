@{
    ViewData["Title"] = "Test Links";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Test Links</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <h2>Test Navigation Links</h2>
        
        <div class="card">
            <div class="card-body">
                <h5>Direct Links:</h5>
                <p><a href="/Identity/Account/Register" class="btn btn-primary">Register (Direct)</a></p>
                <p><a href="/Identity/Account/Login" class="btn btn-success">Login (Direct)</a></p>
                
                <h5>ASP.NET Core Links:</h5>
                <p><a href="~/Identity/Account/Register" class="btn btn-primary">Register (ASP.NET)</a></p>
                <p><a href="~/Identity/Account/Login" class="btn btn-success">Login (ASP.NET)</a></p>
                
                <h5>Other Pages:</h5>
                <p><a href="/Debug" class="btn btn-info">Debug Page</a></p>
                <p><a href="/Test" class="btn btn-warning">Test Page</a></p>
                <p><a href="/" class="btn btn-secondary">Home</a></p>
            </div>
        </div>
        
        <div class="mt-3">
            <p>Current URL: <code id="currentUrl"></code></p>
            <p>User Agent: <code id="userAgent"></code></p>
        </div>
    </div>
    
    <script>
        document.getElementById('currentUrl').textContent = window.location.href;
        document.getElementById('userAgent').textContent = navigator.userAgent;
    </script>
</body>
</html>
