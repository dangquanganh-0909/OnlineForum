@model WebApplication1.Models.Report
@{
    ViewData["Title"] = "Report Bài Viết";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Report Bài Viết</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">Vui lòng chọn lý do report và cung cấp thêm thông tin để giúp chúng tôi xử lý nhanh hơn.</p>

                    <form id="reportForm">
                        <div class="mb-3">
                            <label for="reason" class="form-label">Lý do Report <span class="text-danger">*</span></label>
                            <select class="form-select" id="reason" name="reason" required>
                                <option value="">-- Chọn lý do --</option>
                                <option value="0">Nội dung phản cảm</option>
                                <option value="1">Bạo lực</option>
                                <option value="2">Nội dung phản động</option>
                                <option value="3">Vi phạm pháp luật</option>
                                <option value="4">Spam</option>
                                <option value="5">Quấy rối</option>
                                <option value="6">Vi phạm bản quyền</option>
                                <option value="7">Khác</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Mô tả chi tiết (tùy chọn)</label>
                            <textarea class="form-control" id="description" name="description" rows="4" placeholder="Cung cấp thêm chi tiết về vấn đề..."></textarea>
                            <small class="text-muted">Tối đa 500 ký tự</small>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle"></i>
                            <strong>Lưu ý:</strong> Report giả mạo sẽ bị xử lý theo quy định. Hãy chỉ report các nội dung thực sự vi phạm.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-grow-1">
                                <i class="bi bi-flag"></i> Gửi Report
                            </button>
                            <a href="javascript:history.back()" class="btn btn-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('reportForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const reason = document.getElementById('reason').value;
    const description = document.getElementById('description').value;

    if (!reason) {
        alert('Vui lòng chọn lý do report');
        return;
    }

    try {
        const url = window.location.pathname.split('/');
        const postId = url[url.length - 1];
        
        const response = await fetch('@Url.Action("Post", "Report")?id=' + postId + '&reason=' + reason + '&description=' + encodeURIComponent(description), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        const data = await response.json();
        
        if (data.success) {
            alert(data.message);
            window.history.back();
        } else {
            alert('Lỗi: ' + (data.message || 'Không thể gửi report'));
        }
    } catch (error) {
        alert('Lỗi khi gửi report: ' + error.message);
    }
});
</script>
