@model List<WebApplication1.Models.Report>
@{
    ViewData["Title"] = "Quản Lý Report Bài Viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-flag"></i> Report Bài Viết
        </h2>
        <span class="badge bg-danger">@Model.Count report</span>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle"></i> Không có report nào cần xử lý.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Bài Viết</th>
                        <th>Lý Do Report</th>
                        <th>Người Report</th>
                        <th>Ngày Report</th>
                        <th>Trạng Thái</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model.OrderByDescending(r => r.CreatedAt))
                    {
                        <tr>
                            <td>
                                @if (report.Post != null)
                                {
                                    <strong>@(report.Post.Title.Length > 30 ? report.Post.Title.Substring(0, 30) + "..." : report.Post.Title)</strong>
                                    <br/>
                                    <small class="text-muted">@report.Post.SubCategory?.Name</small>
                                }
                                else
                                {
                                    <span class="text-muted">Bài viết đã bị xóa</span>
                                }
                            </td>
                            <td>
                                @{
                                    var reasonText = report.Reason switch
                                    {
                                        WebApplication1.Models.ReportReason.OffensiveContent => "Nội dung phản cảm",
                                        WebApplication1.Models.ReportReason.Violence => "Bạo lực",
                                        WebApplication1.Models.ReportReason.SubversiveContent => "Nội dung phản động",
                                        WebApplication1.Models.ReportReason.IllegalContent => "Vi phạm pháp luật",
                                        WebApplication1.Models.ReportReason.Spam => "Spam",
                                        WebApplication1.Models.ReportReason.Harassment => "Quấy rối",
                                        WebApplication1.Models.ReportReason.Copyright => "Vi phạm bản quyền",
                                        _ => "Khác"
                                    };
                                }
                                <span class="badge bg-warning">@reasonText</span>
                                @if (!string.IsNullOrEmpty(report.Description))
                                {
                                    <br/>
                                    <small class="text-muted">@(report.Description.Length > 50 ? report.Description.Substring(0, 50) + "..." : report.Description)</small>
                                }
                            </td>
                            <td>
                                @if (report.User != null)
                                {
                                    <a href="@Url.Action("Profile", "User", new { id = report.UserId })">
                                        @(report.User.DisplayName ?? report.User.UserName)
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Người dùng đã xóa</span>
                                }
                            </td>
                            <td>
                                <small>@report.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td>
                                @switch(report.Status)
                                {
                                    case WebApplication1.Models.ReportStatus.Pending:
                                        <span class="badge bg-danger">Chờ xử lý</span>
                                        break;
                                    case WebApplication1.Models.ReportStatus.Reviewed:
                                        <span class="badge bg-info">Đã xem</span>
                                        break;
                                    case WebApplication1.Models.ReportStatus.Resolved:
                                        <span class="badge bg-success">Đã xử lý</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "Report", new { id = report.Id })" class="btn btn-sm btn-primary" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                @if (report.Post != null)
                                {
                                    <a href="@Url.Action("Details", "Post", new { id = report.Post.Id })" class="btn btn-sm btn-info" title="Xem bài viết">
                                        <i class="bi bi-link-45deg"></i> Bài viết
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        function resolveReport(reportId) {
            if (confirm('Bạn chắc chắn muốn đánh dấu report này là đã xử lý?')) {
                fetch('@Url.Action("ResolveReport", "Report")?id=' + reportId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        location.reload();
                    } else {
                        alert('Lỗi: ' + data.message);
                    }
                })
                .catch(error => alert('Lỗi: ' + error.message));
            }
        }
    </script>
}
