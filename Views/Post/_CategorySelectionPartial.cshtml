@model WebApplication1.ViewModels.CreatePostViewModel

<div class="row">
    <!-- Main Category Dropdown -->
    <div class="col-md-6">
        <div class="form-group">
            <label asp-for="MainCategoryId" class="form-label">
                <i class="fas fa-layer-group"></i> Cụm Danh Mục
            </label>
            <select asp-for="MainCategoryId" id="mainCategorySelect" 
                    class="form-control form-select"
                    asp-items="@ViewBag.MainCategories">
                <option value="">-- Chọn cụm danh mục --</option>
            </select>
            <span asp-validation-for="MainCategoryId" class="text-danger"></span>
        </div>
    </div>
    
    <!-- Sub Category Dropdown -->
    <div class="col-md-6">
        <div class="form-group">
            <label asp-for="SubCategoryId" class="form-label">
                <i class="fas fa-folder"></i> Chuyên Mục
            </label>
            <select asp-for="SubCategoryId" id="subCategorySelect" 
                    class="form-control form-select"
                    asp-items="@ViewBag.SubCategories">
                <option value="">-- Chọn chuyên mục --</option>
            </select>
            <span asp-validation-for="SubCategoryId" class="text-danger"></span>
            <small id="subCategoryHelp" class="form-text text-muted" style="display: none;">
                <i class="fas fa-spinner fa-spin"></i> Đang tải chuyên mục...
            </small>
        </div>
    </div>
</div>
