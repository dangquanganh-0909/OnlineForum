@model WebApplication1.ViewModels.PostIndexViewModel
@{
    ViewData["Title"] = "Diễn Đàn Thảo Luận";
}

<div class="container" style="margin-top: 24px;">
    <!-- Hero Section -->
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 40px; border-radius: 12px; margin-bottom: 32px; text-align: center;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 16px;">
            <i class="fas fa-comments" style="font-size: 3rem;"></i>
            <h1 style="margin: 0; font-size: 2.5rem; font-weight: bold;">Diễn Đàn Thảo Luận</h1>
        </div>
        <p style="margin: 0; font-size: 1.1rem; opacity: 0.9;">Cộng đồng chia sẻ kiến thức và thảo luận về mọi chủ đề</p>
    </div>

    <!-- Search Bar -->
    <div class="card" style="margin-bottom: 24px;">
        <form method="get" asp-action="Index">
            <div style="display: flex; gap: 12px; align-items: end; flex-wrap: wrap;">
                <div class="form-group" style="flex: 1; margin-bottom: 0; min-width: 200px;">
                    <input type="text" name="search" value="@Model.SearchTerm" 
                           class="form-control" placeholder="Tìm kiếm bài viết..." />
                </div>
                <div class="form-group" style="margin-bottom: 0; min-width: 180px;">
                    <select name="mainCategoryId" class="form-control" id="mainCategorySelect">
                        <option value="">Tất Cả Cụm Danh Mục</option>
                        @foreach (var mainCategory in Model.MainCategories)
                        {
                            <option value="@mainCategory.Id" selected="@(Model.CurrentMainCategoryId == mainCategory.Id)">
                                @mainCategory.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 0; min-width: 180px;">
                    <select name="subCategoryId" class="form-control" id="subCategorySelect">
                        <option value="">Tất Cả Chuyên Mục</option>
                        @foreach (var subCategory in Model.SubCategories)
                        {
                            <option value="@subCategory.Id" 
                                    data-main-category="@subCategory.MainCategoryId"
                                    selected="@(Model.CurrentSubCategoryId == subCategory.Id)"
                                    style="@(Model.CurrentMainCategoryId.HasValue && Model.CurrentMainCategoryId != subCategory.MainCategoryId ? "display: none;" : "")">
                                @subCategory.Name
                            </option>
                        }
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 0; min-width: 160px;">
                    <select name="sortBy" class="form-control">
                        <option value="recent" selected="@(Model.SortBy == "recent")">Mới Nhất</option>
                        <option value="views" selected="@(Model.SortBy == "views")">Lượt Xem</option>
                        <option value="interaction" selected="@(Model.SortBy == "interaction")">Tương Tác</option>
                        <option value="length" selected="@(Model.SortBy == "length")">Độ Dài</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Tìm Kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Create Post Button -->
    @if (User.Identity!.IsAuthenticated)
    {
        <div style="text-align: center; margin-bottom: 32px;">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i> Tạo Bài Viết Mới
            </a>
        </div>
    }

    <!-- MainCategory Cards -->
    @foreach (var mainCategory in Model.MainCategories)
    {
        <div style="margin-bottom: 48px;">
            <!-- MainCategory Header -->
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding: 16px; background: linear-gradient(90deg, #f8f9fa 0%, #e9ecef 100%); border-radius: 12px; border-left: 4px solid #007bff;">
                <div style="background: #007bff; color: white; padding: 12px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-layer-group" style="font-size: 1.5rem;"></i>
                </div>
                <div style="flex: 1;">
                    <h2 style="margin: 0; color: #495057; font-weight: bold;">@mainCategory.Name</h2>
                    <div style="display: flex; align-items: center; gap: 16px; margin-top: 4px;">
                        <span style="background: #007bff; color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold;">
                            #@mainCategory.Order
                        </span>
                        <span style="color: #6c757d; font-size: 0.9rem;">
                            @mainCategory.SubCategories.Count() chuyên mục
                        </span>
                    </div>
                </div>
            </div>

            <!-- SubCategory Grid -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px;">
                @foreach (var subCategory in mainCategory.SubCategories)
                {
                    <div class="card subcategory-card" style="border: 1px solid #e9ecef; border-radius: 12px; transition: all 0.3s ease; cursor: pointer;" 
                         onclick="window.location.href='@Url.Action("Index", "Home", new { subCategoryId = subCategory.Id })'">>
                        <div style="padding: 24px;">
                            <!-- SubCategory Header -->
                            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
                                <div style="font-size: 2rem;">@subCategory.Icon</div>
                                <div style="flex: 1;">
                                    <h3 style="margin: 0; color: #212529; font-size: 1.3rem; font-weight: bold;">@subCategory.Name</h3>
                                    <p style="margin: 4px 0 0 0; color: #6c757d; font-size: 0.9rem;">@subCategory.Description</p>
                                </div>
                            </div>

                            <!-- Stats Row -->
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-top: 1px solid #f1f3f4;">
                                <div style="text-align: center;">
                                    <div style="color: #007bff; font-size: 1.5rem; font-weight: bold; margin-bottom: 4px;">
                                        @Model.Posts.Count(p => p.SubCategoryId == subCategory.Id)
                                    </div>
                                    <div style="color: #6c757d; font-size: 0.8rem; text-transform: uppercase;">BÀI VIẾT</div>
                                </div>
                                <div style="flex: 1; margin-left: 24px;">
                                    @{
                                        var latestPost = Model.Posts.Where(p => p.SubCategoryId == subCategory.Id)
                                                                   .OrderByDescending(p => p.CreatedAt)
                                                                   .FirstOrDefault();
                                    }
                                    @if (latestPost != null)
                                    {
                                        <div style="font-size: 0.8rem; color: #6c757d; margin-bottom: 4px;">BÀI VIẾT MỚI NHẤT</div>
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            @if (!string.IsNullOrEmpty(latestPost.User.Avatar))
                                            {
                                                <img src="@latestPost.User.Avatar" alt="Avatar" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div style="width: 24px; height: 24px; border-radius: 50%; background-color: #007bff; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 0.7rem;">
                                                    @((latestPost.User.DisplayName ?? latestPost.User.UserName)?.Substring(0, 1).ToUpper())
                                                </div>
                                            }
                                            <div>
                                                <div style="font-weight: 500; color: #212529; font-size: 0.9rem; margin-bottom: 2px;">
                                                    <a asp-action="Details" asp-route-id="@latestPost.Id" style="text-decoration: none; color: inherit;">
                                                        @(latestPost.Title.Length > 40 ? latestPost.Title.Substring(0, 40) + "..." : latestPost.Title)
                                                    </a>
                                                </div>
                                                <div style="font-size: 0.8rem; color: #6c757d;">
                                                    <span>@(latestPost.User.DisplayName ?? latestPost.User.UserName)</span>
                                                    <span style="margin: 0 8px;">•</span>
                                                    <span>@latestPost.CreatedAt.ToString("MMM dd, yyyy")</span>
                                                    <span style="margin: 0 8px;">•</span>
                                                    <span>@latestPost.Views lượt xem</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="text-align: center; color: #6c757d; font-size: 0.9rem; padding: 12px;">
                                            <i class="fas fa-file-alt" style="margin-bottom: 8px; display: block; opacity: 0.5;"></i>
                                            Chưa có bài viết
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Add CSS for hover effects -->
<style>
.subcategory-card:hover {
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    transform: translateY(-2px);
}

.card {
    transition: all 0.3s ease;
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

.form-control {
    border-radius: 8px;
    border: 1px solid #e9ecef;
    padding: 10px 16px;
    transition: border-color 0.3s ease;
}

.form-control:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
}
</style>

<script>
// Cascading dropdown for MainCategory -> SubCategory
document.addEventListener('DOMContentLoaded', function() {
    const mainCategorySelect = document.getElementById('mainCategorySelect');
    const subCategorySelect = document.getElementById('subCategorySelect');
    
    if (mainCategorySelect && subCategorySelect) {
        mainCategorySelect.addEventListener('change', function() {
            const selectedMainCategoryId = this.value;
            const subCategoryOptions = subCategorySelect.querySelectorAll('option');
            
            subCategoryOptions.forEach(function(option) {
                if (option.value === '') {
                    // Always show "Tất Cả Chuyên Mục" option
                    option.style.display = 'block';
                } else {
                    const mainCategoryId = option.getAttribute('data-main-category');
                    if (selectedMainCategoryId === '' || mainCategoryId === selectedMainCategoryId) {
                        option.style.display = 'block';
                    } else {
                        option.style.display = 'none';
                    }
                }
            });
            
            // Reset SubCategory selection if current selection is not visible
            if (subCategorySelect.value !== '') {
                const currentOption = subCategorySelect.querySelector(`option[value="${subCategorySelect.value}"]`);
                if (currentOption && currentOption.style.display === 'none') {
                    subCategorySelect.value = '';
                }
            }
        });
        
        // Trigger change event on page load to set initial state
        mainCategorySelect.dispatchEvent(new Event('change'));
    }
});
</script>