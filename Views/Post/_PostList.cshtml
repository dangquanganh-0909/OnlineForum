@model WebApplication1.ViewModels.PostIndexViewModel
@{
    ViewData["Title"] = "Danh sách bài viết";
}

<style>
    .sort-options {
        margin-bottom: 20px;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 6px;
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sort-options label {
        margin: 0;
        font-weight: 500;
        color: #333;
    }

    .sort-btn {
        padding: 8px 16px;
        border: 1px solid #ddd;
        background: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.9rem;
    }

    .sort-btn:hover {
        border-color: var(--primary-color);
        color: var(--primary-color);
    }

    .sort-btn.active {
        background: var(--primary-color);
        color: white;
        border-color: var(--primary-color);
    }
</style>

<!-- Sort Options -->
<div class="sort-options">
    <label>Sắp xếp theo:</label>
    <button class="sort-btn @(Model.SortBy == "recent" ? "active" : "")" type="button" onclick="sortPosts('recent')">
        <i class="fas fa-clock"></i> Mới Nhất
    </button>
    <button class="sort-btn @(Model.SortBy == "views" ? "active" : "")" type="button" onclick="sortPosts('views')">
        <i class="fas fa-eye"></i> Lượt Xem
    </button>
    <button class="sort-btn @(Model.SortBy == "interaction" ? "active" : "")" type="button" onclick="sortPosts('interaction')">
        <i class="fas fa-comments"></i> Tương Tác
    </button>
    <button class="sort-btn @(Model.SortBy == "length" ? "active" : "")" type="button" onclick="sortPosts('length')">
        <i class="fas fa-align-left"></i> Độ Dài
    </button>
</div>

<!-- Posts List -->
@if (Model.Posts.Any())
{
    @foreach (var post in Model.Posts)
    {
        <article class="post-card card">
            <div class="card-header">
                <h2 class="card-title">
                    <a asp-action="Details" asp-route-id="@post.Id" 
                       style="text-decoration: none; color: inherit;">
                        @post.Title
                    </a>
                </h2>
                <div class="post-meta">
                    <span class="tag category" style="background-color: @post.Category.Color;">
                        @post.Category.Name
                    </span>
                    <span style="display: flex; align-items: center; gap: 8px;">
                        @if (!string.IsNullOrEmpty(post.User.Avatar))
                        {
                            <img src="@post.User.Avatar" alt="Avatar" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" />
                        }
                        else
                        {
                            <div style="width: 20px; height: 20px; border-radius: 50%; background-color: var(--primary-color); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 0.7rem;">
                                @((post.User.DisplayName ?? post.User.UserName)?.Substring(0, 1).ToUpper())
                            </div>
                        }
                        <a asp-controller="User" asp-action="Profile" asp-route-id="@post.UserId">
                            @(post.User.DisplayName ?? post.User.UserName)
                        </a>
                    </span>
                    <span>
                        <i class="fas fa-clock"></i>
                        @post.CreatedAt.ToString("MMM dd, yyyy")
                    </span>
                    @if (post.UpdatedAt.HasValue)
                    {
                        <span class="text-muted">
                            <i class="fas fa-edit"></i> Updated @post.UpdatedAt.Value.ToString("MMM dd, yyyy")
                        </span>
                    }
                </div>
            </div>
            
            <div style="margin-bottom: 16px;">
                <p>@Html.Raw(post.Content.Length > 200 ? post.Content.Substring(0, 200) + "..." : post.Content)</p>
                
                @if (!string.IsNullOrEmpty(post.ImagePath))
                {
                    <div style="margin-top: 12px;">
                        <img src="@post.ImagePath" alt="Ảnh bài viết" 
                             style="max-width: 200px; height: auto; border-radius: 6px; cursor: pointer;" 
                             onclick="window.location.href='@Url.Action("Details", new { id = post.Id })'" />
                        <span style="color: var(--text-muted); font-size: 0.9rem; margin-left: 8px;">
                            <i class="fas fa-image"></i> Ảnh
                        </span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(post.VideoPath))
                {
                    <div style="margin-top: 12px;">
                        <span style="color: var(--text-muted); font-size: 0.9rem;">
                            <i class="fas fa-video"></i> Video - Click để xem
                        </span>
                    </div>
                }
            </div>

            <div class="post-stats">
                <div class="stat-item">
                    <i class="fas fa-eye"></i>
                    <span>@post.Views lượt xem</span>
                </div>
                <div class="stat-item">
                    <i class="fas fa-heart"></i>
                    <span>@post.PostLikes.Count thích</span>
                </div>
                <div class="stat-item">
                    <i class="fas fa-comment"></i>
                    <span>@post.Comments.Count bình luận</span>
                </div>
                
                @if (User.Identity!.IsAuthenticated)
                {
                    @if (post.UserId == ViewContext.HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin") || User.IsInRole("Moderator"))
                    {
                        <div class="stat-item" style="display: flex; gap: 8px; align-items: center;">
                            <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline btn-sm">
                                <i class="fas fa-edit"></i> Sửa
                            </a>
                            <form asp-action="Delete" asp-route-id="@post.Id" method="post" style="display: inline;" 
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa bài viết này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline btn-sm" style="color: var(--danger-color); border-color: var(--danger-color);">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>

            @if (post.PostTags.Any())
            {
                <div style="margin-top: 16px;">
                    @foreach (var postTag in post.PostTags)
                    {
                        <span class="tag">@postTag.Tag.Name</span>
                    }
                </div>
            }
        </article>
    }

    @if (Model.TotalPages > 1)
    {
        <div class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <a href="javascript:void(0);" onclick="loadCategoryPosts(@(Model.CurrentSubCategoryId ?? 0), document.getElementById('categoryTitle').textContent)" class="page-link">
                    <i class="fas fa-chevron-left"></i> Trang Trước
                </a>
            }

            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <a href="javascript:void(0);" 
                   class="page-link @(i == Model.CurrentPage ? "active" : "")">
                    @i
                </a>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="javascript:void(0);" onclick="loadCategoryPosts(@(Model.CurrentSubCategoryId ?? 0), document.getElementById('categoryTitle').textContent)" class="page-link">
                    Trang Sau <i class="fas fa-chevron-right"></i>
                </a>
            }
        </div>
    }
}
else
{
    <div class="card text-center">
        <div style="padding: 48px;">
            <i class="fas fa-comments" style="font-size: 4rem; color: var(--text-muted); margin-bottom: 16px;"></i>
            <h3>Không có bài viết nào</h3>
            <p class="text-muted">Hãy là người đầu tiên bắt đầu cuộc thảo luận!</p>
            @if (User.Identity!.IsAuthenticated)
            {
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Tạo Bài Viết Đầu Tiên
                </a>
            }
        </div>
    </div>
}

<script>
    function sortPosts(sortType) {
        const subCategoryId = @(Model.CurrentSubCategoryId ?? 0);
        const mainCategoryId = @(Model.CurrentMainCategoryId ?? 0);
        if (subCategoryId || mainCategoryId) {
            if (typeof loadCategoryPosts !== 'undefined') {
                const url = subCategoryId ? 
                    '/Post/Index?subCategoryId=' + subCategoryId + '&sortBy=' + sortType :
                    '/Post/Index?mainCategoryId=' + mainCategoryId + '&sortBy=' + sortType;
                fetch(url)
                    .then(function(response) { return response.text(); })
                    .then(function(html) {
                        document.getElementById('postsList').innerHTML = html;
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                    });
            } else {
                window.location.href = '/Post/Index?categoryId=' + categoryId + '&sortBy=' + sortType;
            }
        } else {
            window.location.href = '/Post/Index?sortBy=' + sortType;
        }
    }
</script>
