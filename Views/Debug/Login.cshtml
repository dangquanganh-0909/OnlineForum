@{
    ViewData["Title"] = "Test Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Test Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4>Test Login Form</h4>
                    </div>
                    <div class="card-body">
                        <form id="testLoginForm">
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" class="form-control" id="password" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Test Login</button>
                        </form>
                        <div id="result" class="mt-3"></div>
                        
                        <hr>
                        
                        <h5>Quick Test Users:</h5>
                        <button class="btn btn-info btn-sm" onclick="fillTestUser()">Fill Test User</button>
                        <p class="small mt-2">
                            Test Email: test@example.com<br>
                            Test Password: Test123456
                        </p>
                    </div>
                </div>
                
                <div class="mt-3">
                    <a href="/Identity/Account/Login" class="btn btn-secondary">Go to Real Login</a>
                    <a href="/Identity/Account/Register" class="btn btn-success">Go to Register</a>
                    <a href="/Debug" class="btn btn-info">Back to Debug</a>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function fillTestUser() {
            document.getElementById('email').value = 'test@example.com';
            document.getElementById('password').value = 'Test123456';
        }
        
        document.getElementById('testLoginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            try {
                const response = await fetch('/Test/TestLogin', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `email=${encodeURIComponent(email)}&password=${encodeURIComponent(password)}`
                });
                
                const result = await response.json();
                const resultDiv = document.getElementById('result');
                
                if (result.success) {
                    resultDiv.innerHTML = `<div class="alert alert-success">${result.message}</div>`;
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger">${result.message}</div>`;
                }
            } catch (error) {
                document.getElementById('result').innerHTML = `<div class="alert alert-danger">Error: ${error.message}</div>`;
            }
        });
    </script>
</body>
</html>
